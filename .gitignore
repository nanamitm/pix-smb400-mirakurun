# ---- Secrets (NEVER commit) ----
boot/rsa_key.pem                    # RSA private key for USB Boot signing
boot/usb_boot_files/rsa_key.pem    # same key, copied by make_usb_boot.py
.acas_key                           # ACAS master key (device-specific)

# ---- Build artifacts ----
# Binaries built by `make build-bins` (src/ -> bin/)
/bin/*
!/bin/.gitkeep
*.o

# Boot files generated by make_usb_boot.py / build_initramfs.sh
boot/bootargs.bin
boot/root_rsa_pub_crc.bin
boot/initramfs_patched.uimg
boot/usb_boot_files/bootargs.bin
boot/usb_boot_files/root_rsa_pub_crc.bin
boot/usb_boot_files/initramfs_patched.uimg

# ---- Pulled from device (proprietary Android system libraries) ----
/android-libs/

# ---- User-supplied firmware / kernel image & extraction output ----
kernel.img
_*.extracted/
firmware_extracted/

# ---- Work dirs ----
# Mirakurun-BS4K clone built during `make deploy-mirakurun`
/tmp/
node_modules/

# ---- Python ----
__pycache__/
*.pyc

# ---- OS / editor junk ----
.DS_Store
*.swp
